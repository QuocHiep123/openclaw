# AI Research Lab Automation System
# Copy this file to .env and fill in your values

# --- LLM Provider (choose one or both) ---
OPENAI_API_KEY=your-openai-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# --- Runtime mode ---
# bot | server | cli | daily
APP_MODE=bot

# --- LLM Model Settings ---
LLM_PROVIDER=openai
# Options: openai, google
LLM_MODEL=gpt-4o-mini
# For google: gemini-2.5-flash

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=
# Comma-separated Telegram user IDs (leave empty to allow all)

# --- Language ---
# vi = Vietnamese, en = English
BOT_LANGUAGE=vi

# --- Chroma Vector DB ---
CHROMA_PERSIST_DIR=./data/chroma

# --- arXiv Settings ---
ARXIV_DEFAULT_CATEGORIES=cs.AI,cs.LG,cs.CL
ARXIV_MAX_PAPERS=50

# --- MCP Server ---
MCP_HOST=0.0.0.0
MCP_PORT=8100

# --- Scheduled Daily Report ---
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR=7
DAILY_REPORT_MINUTE=0
# Set this to your Telegram chat ID to receive daily reports
DAILY_REPORT_CHAT_ID=

# --- Proxy (required if Telegram is blocked in your network) ---
# Example: PROXY_URL=http://127.0.0.1:7890
# Example: PROXY_URL=socks5://127.0.0.1:1080
PROXY_URL=

# --- Logging ---
LOG_LEVEL=INFO
